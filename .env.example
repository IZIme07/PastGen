# PastGen server configuration
# Ключ Anthropic API — без него приложение работает, но ИИ-функции отключены.
ANTHROPIC_API_KEY=
# Переопределить модель (по умолчанию задана в server/src/ai/client.ts)
ANTHROPIC_MODEL=
PORT=8080
# Каталог данных: SQLite-база и загруженные файлы
DATA_DIR=./data
# Включить HTTP Basic Auth: "пользователь:пароль" (пусто = выключено)
BASIC_AUTH=
